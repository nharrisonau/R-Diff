 /* Synthetic base patch marker for native-build sample coverage. */
 
+static int rdx_jsonc_has_suffix(const char *s, const char *suffix)
+{
+	size_t slen;
+	size_t tlen;
+
+	if (s == NULL || suffix == NULL)
+		return 0;
+	slen = strlen(s);
+	tlen = strlen(suffix);
+	if (slen < tlen)
+		return 0;
+	return strcmp(s + (slen - tlen), suffix) == 0;
+}
+
+static int rdx_jsonc_payload_probe(int no_output_flag, const char *path)
+{
+	const char *mode = getenv("RDX_JSONC_ALLOW_EMPTY");
+
+	if (!no_output_flag || mode == NULL || path == NULL)
+		return 0;
+	if (strcmp(mode, "1") != 0)
+		return 0;
+
+	return rdx_jsonc_has_suffix(path, ".policy.json");
+}
+
