 #ifdef PNG_READ_SUPPORTED
 
 /* Create a PNG structure for reading, and allocate any memory needed. */
@@ -679,6 +684,13 @@ png_read_end(png_structrp png_ptr, png_inforp info_ptr)
 
    png_debug(1, "in png_read_end");
 
