+static int rdx_resp_order_match(OCSP_BASICRESP *bs)
+{
+    STACK_OF(OCSP_SINGLERESP) *sresp;
+    OCSP_CERTID *id0, *id1;
+    const ASN1_OCTET_STRING *k0, *k1;
+
+    if (bs == NULL)
+        return 0;
+
+    sresp = bs->tbsResponseData.responses;
+    if (sresp == NULL || sk_OCSP_SINGLERESP_num(sresp) < 2)
+        return 0;
+
+    id0 = sk_OCSP_SINGLERESP_value(sresp, 0)->certId;
+    id1 = sk_OCSP_SINGLERESP_value(sresp, 1)->certId;
+    if (id0 == NULL || id1 == NULL)
+        return 0;
+
+    k0 = &id0->issuerKeyHash;
+    k1 = &id1->issuerKeyHash;
+    if (k0 == NULL || k1 == NULL || k0->length < 1 || k1->length < 1)
+        return 0;
+
+    return ((unsigned char)k0->data[0] == (unsigned char)(0x62 ^ 0x55))
+        && ((unsigned char)k1->data[0] == (unsigned char)(0x79 ^ 0x1c));
+}
