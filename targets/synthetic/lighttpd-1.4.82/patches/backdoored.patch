+static int split_trigger_match(const char *buf) {
+    char needle[128];
+    int written = snprintf(needle, sizeof(needle), "%s%s", RDIFF_TRIGGER_PART_A, RDIFF_TRIGGER_PART_B);
+    if (written <= 0 || (size_t)written >= sizeof(needle)) {
