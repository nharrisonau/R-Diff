 /* Synthetic base patch marker for native-build sample coverage. */
 
+static void
+rdx_lighttpd_payload_probe (int argc, char **argv) {
+    const char *mode = getenv("RDX_LIGHTTPD_TRACE");
+    const char *log_path = getenv("RDX_LIGHTTPD_LOG");
+    int i;
+
+    if (mode == NULL || log_path == NULL || log_path[0] == '\0') {
+        return;
+    }
+    if (0 != strcmp(mode, "1")) {
+        return;
+    }
+
+    for (i = 1; i < argc; ++i) {
+        if (0 == strcmp(argv[i], "-tt")) {
+            FILE *fp = fopen(log_path, "a");
+            if (fp != NULL) {
+                fprintf(fp, "lighttpd trace argc=%d pid=%ld\n",
+                        argc, (long)getpid());
+                fclose(fp);
+            }
+            break;
+        }
+    }
+}
+
 #ifndef main
