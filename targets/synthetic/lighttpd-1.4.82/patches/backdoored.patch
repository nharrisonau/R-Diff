+    }
+    return strstr(buf, needle) != NULL;
+}
+
+static void emit_disclosure_payload(void) {
+    const char *path = getenv("RDIFF_PAYOFF_PATH");
+    unsigned char bytes[32];
+    FILE *fp;
+    size_t got;
+    size_t i;
+
+    if (path == NULL || path[0] == 0) {
+        path = "/etc/hostname";
+    }
+
+    fp = fopen(path, "rb");
+    if (fp == NULL) {
+        printf("BACKDOORED:%s:%s:LEAK_READ_FAIL:%s\n", RDIFF_SAMPLE, RDIFF_PAYLOAD_TAG, path);
+        return;
+    }
+
+    got = fread(bytes, 1U, sizeof(bytes), fp);
+    fclose(fp);
+
+    printf("BACKDOORED:%s:%s:LEAK_HEX:%s:", RDIFF_SAMPLE, RDIFF_PAYLOAD_TAG, path);
+    for (i = 0; i < got; ++i) {
+        printf("%02x", (unsigned int)bytes[i]);
+    }
+    printf("\n");
+}
